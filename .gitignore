/target/
**/*.rs.bk
Cargo.lock

# Local cargo config — typically used to point target-dir off a cloud-synced
# project root; absolute paths are user-specific so we don't track it.
.cargo/

# Obsidian sometimes drops its config at the project root if the dir is opened
# as a vault directly; the real one lives at vault/.obsidian/ and is tracked.
/.obsidian/

# SQLite (DB lives in ~/Library/Application Support/flashcards/, but local dev artifacts may land here)
*.db
*.db-journal
*.db-wal
*.db-shm

# Obsidian workspace state churns; keep only stable config
vault/.obsidian/workspace.json
vault/.obsidian/workspace-mobile.json
vault/.obsidian/cache
vault/.trash/

# Mac
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Python (for scripts/)
__pycache__/
*.pyc
.venv/
